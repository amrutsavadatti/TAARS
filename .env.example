# === LLM ===
LLM_PROVIDER=openai                # openai | anthropic
LLM_MODEL=gpt-4o-mini             # or claude-sonnet-4-6 for anthropic
LLM_API_KEY=sk-...
EMBEDDING_PROVIDER=openai          # openai | huggingface
EMBEDDING_MODEL=text-embedding-3-small
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# === Vector DB ===
VECTOR_DB=chroma
CHROMA_PERSIST_DIR=./data/chroma

# === Valkey ===
VALKEY_URL=redis://localhost:6379

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./data/conversations.db

# === OTP Gate (optional visitor authentication) ===
ENABLE_OTP_GATE=false              # true | false
OTP_GATE_MODE=upfront              # upfront | after_n
OTP_GATE_AFTER_N_QUESTIONS=3
EMAIL_PROVIDER=resend              # resend | smtp | sendgrid
EMAIL_FROM=noreply@yourdomain.com
OTP_EXPIRY_SECONDS=300
OTP_MAX_RETRIES=3

# === Rate Limiting ===
RATE_LIMIT_PER_IP_PER_DAY=50
RATE_LIMIT_PER_EMAIL_PER_DAY=20

# === Session ===
SESSION_TTL_MINUTES=30
SESSION_CONTEXT_WINDOW=5
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY_HOURS=24

# === Chat ===
ENABLE_HYDE=false
RETRIEVAL_TOP_K=5
RERANK_TOP_N=3
SIMILARITY_THRESHOLD=0.65
ENABLE_RESPONSE_CACHE=true
SESSION_END_TIMEOUT_MINUTES=10

# === Ingestion ===
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,png,jpg,jpeg,txt,md,docx

# === Owner ===
OWNER_NAME=Amrut
OWNER_CONTACT_EMAIL=ryan@yourdomain.com
OWNER_NOTIFICATION_CHANNEL=email   # email | slack
OWNER_SLACK_WEBHOOK=
CAL_COM_BOOKING_URL=http://localhost:3000/coffee-chat

# === Widget ===
SUGGESTED_QUESTIONS=What is Amrut's tech stack?,Tell me about his recent projects,What's his education background?
WIDGET_GREETING=Hi! I'm Amrut's career assistant. Ask me anything about his experience, skills, and projects.
WIDGET_THEME_PRIMARY=#2563eb

# === Analytics ===
UMAMI_SCRIPT_URL=http://localhost:3001/script.js
UMAMI_WEBSITE_ID=your-website-id

# === Agents ===
ENABLE_FOLLOW_UP_EMAIL=true
FOLLOW_UP_DELAY_MINUTES=90
FOLLOW_UP_MIN_QUESTIONS=3
FOLLOW_UP_INTENT_THRESHOLD=0.7
ENABLE_OWNER_NOTIFICATIONS=true
ENABLE_CONTENT_GAP_DETECTION=true
WEEKLY_DIGEST_DAY=monday
WEEKLY_DIGEST_HOUR=9
OWNER_APPROVAL_REQUIRED=false
